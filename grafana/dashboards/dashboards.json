{
  "id": null,
  "uid": "tictactoe-overview",
  "title": "TicTacToe Overview",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "5s",
  "timezone": "browser",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "tags": [
    "tictactoe",
    "prometheus",
    "loki"
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Games",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ttt_active_games"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "value",
        "graphMode": "none",
        "colorMode": "value"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "App Memory Over Time (RSS)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{job=\"tictactoe-app\"}",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests Per Second By Route",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(ttt_http_requests_total[1m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Application Logs (Loki)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"tictactoe\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}