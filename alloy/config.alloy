local.file_match "tictactoe_logs" {
  path_targets = [
    {
      __path__ = "/var/log/tictactoe/app.log",
      job      = "tictactoe",
    },
  ]
}

loki.source.file "tictactoe" {
  targets    = local.file_match.tictactoe_logs.targets
  forward_to = [loki.write.default.receiver]
}

loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
